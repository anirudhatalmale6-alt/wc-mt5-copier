{
  "manifest_version": 3,
  "name": "WealthCharts → MT5 Trade Copier",
  "version": "1.0.0",
  "description": "Intercepts trade signals from WealthCharts and forwards them to the MT5 bridge middleware.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.wealthcharts.com/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.wealthcharts.com/*"],
      "js": ["injector.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["https://*.wealthcharts.com/*"]
    }
  ]
}
